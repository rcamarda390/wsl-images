# =============================================================================
# agentmemory runtime configuration
# =============================================================================
# Copy to .env and uncomment the vars you need.
# The .env file is bind-mounted into the agentmemory container only — never
# into iii-engine (which needs no LLM config).
#
# SECURITY: never commit .env to git. It is .gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Container registry
# Set to your internal Artifactory registry for air-gapped work deployments.
# Leave empty (or default) for home / internet-connected use.
# -----------------------------------------------------------------------------
# REGISTRY=your-artifactory.example.com/docker-local

# -----------------------------------------------------------------------------
# Image versions
# -----------------------------------------------------------------------------
# AGENTMEMORY_III_VERSION=0.11.2   # DO NOT BUMP without testing — see compose comments
# AGENTMEMORY_VERSION=0.9.21

# -----------------------------------------------------------------------------
# LLM provider — pick ONE block
# -----------------------------------------------------------------------------
#
# Without a provider key, agentmemory runs in noop mode:
# - Observations indexed via synthetic (zero-LLM) compression
# - Hybrid BM25 keyword search still works
# - LLM summarization, reflection, and consolidation are DISABLED
#
# Detection order: OPENAI_API_KEY → MINIMAX_API_KEY → ANTHROPIC_API_KEY
#                  → GEMINI_API_KEY → OPENROUTER_API_KEY → noop

# ---- AWS Bedrock via LiteLLM proxy (WORK / air-gapped) ---------------------
# Assumes LiteLLM is running (separately or alongside agentmemory).
# LiteLLM handles the Bedrock auth; agentmemory just sees an OpenAI endpoint.
#
# OPENAI_API_KEY=dummy-litellm-key
# OPENAI_BASE_URL=http://litellm:4000/v1
# OPENAI_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0   # or your Bedrock model alias

# ---- Anthropic (HOME) -------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- OpenAI (HOME) ----------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com

# ---- Google Gemini (HOME) ---------------------------------------------------
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# ---- Ollama (local, home or work) -------------------------------------------
# OPENAI_API_KEY=dummy
# OPENAI_BASE_URL=http://ollama:11434/v1
# OPENAI_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Embedding provider (optional — improves semantic search quality)
# Default (no key): BM25 keyword-only search
# With key: hybrid BM25 + vector search
# -----------------------------------------------------------------------------
# EMBEDDING_PROVIDER=local   # uses Xenova/all-MiniLM-L6-v2 (requires full image build)

# For Bedrock/LiteLLM embeddings:
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
# OPENAI_EMBEDDING_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# Auth (recommended when exposed beyond loopback)
# -----------------------------------------------------------------------------
# AGENTMEMORY_SECRET=change-me-use-a-strong-random-string

# -----------------------------------------------------------------------------
# Feature flags (all off by default — enable incrementally)
# -----------------------------------------------------------------------------
# AGENTMEMORY_TOOLS=all                  # expose all 51 tools (default: core 7)
# AGENTMEMORY_AUTO_COMPRESS=true         # LLM compression on every batch
# CONSOLIDATION_ENABLED=true             # 4-tier memory consolidation pipeline
# GRAPH_EXTRACTION_ENABLED=true          # concept-graph edges on remember
# AGENTMEMORY_REFLECT=true               # auto-synthesize lessons from memories

# -----------------------------------------------------------------------------
# Ports (only change if you have conflicts)
# -----------------------------------------------------------------------------
# III_REST_PORT=3111
# III_STREAMS_PORT=3112

# -----------------------------------------------------------------------------
# Fallback LLM chain (retry on rate limit)
# -----------------------------------------------------------------------------
# FALLBACK_PROVIDERS=anthropic,gemini
